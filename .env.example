# ─── LLM ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── LangSmith (optional — enables tracing + evals) ──────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pair-cooking
LANGSMITH_EVAL_UPLOAD_RESULTS=false
# Backwards-compatible LangChain env vars are still supported if you already use them:
# LANGCHAIN_TRACING_V2=
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Backend ─────────────────────────────────────────────────────────────────
API_PORT=8000

# ─── Frontend (Vite exposes vars prefixed with VITE_) ─────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
