# ─── LLM ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── LangSmith (optional — enables tracing + evals) ──────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
# Default project for render-agent traces; main-agent traces go to "main-agent" project automatically.
LANGCHAIN_PROJECT=render-agent

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Backend ─────────────────────────────────────────────────────────────────
API_PORT=8000

# ─── Frontend (Vite exposes vars prefixed with VITE_) ─────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
